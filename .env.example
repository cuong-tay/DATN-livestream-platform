# Frontend gọi backend trực tiếp, không qua Vite proxy.
# Có thể truyền origin thuần hoặc full base path.

# Local dev mặc định đã là http://localhost:8080/api/v1 nên có thể bỏ trống file này.
# Ví dụ khác:
# VITE_API_BASE_URL=http://localhost:8081
# VITE_API_BASE_URL=https://api.yourdomain.com/api/v1
VITE_API_BASE_URL=http://localhost:8080/api/v1

# Nếu bỏ trống, frontend sẽ tự suy ra từ VITE_API_BASE_URL:
# http://localhost:8080/api/v1 -> ws://localhost:8080/api/v1/ws
# https://api.yourdomain.com/api/v1 -> wss://api.yourdomain.com/api/v1/ws
VITE_WS_URL=

# Endpoint upload avatar multipart (JWT).
# Có thể là path tương đối (sẽ ghép với VITE_API_BASE_URL) hoặc URL tuyệt đối.
# Ví dụ:
# VITE_AVATAR_UPLOAD_ENDPOINT=/auth/me/avatar
# VITE_AVATAR_UPLOAD_ENDPOINT=https://api.yourdomain.com/api/v1/files/avatar
VITE_AVATAR_UPLOAD_ENDPOINT=/auth/me/avatar

# Tên field multipart mà backend nhận file avatar.
# Ví dụ backend nhận @RequestPart("avatar") thì đặt là avatar.
VITE_AVATAR_UPLOAD_FIELD=file

# Debug logs cho luồng HLS (.m3u8/.ts) trong player (hls.js events)
VITE_DEBUG_STREAM=false

# Debug logs cho API VOD/sessions/retry-vod (liên quan upload Cloudflare/R2)
VITE_DEBUG_VOD_API=false
