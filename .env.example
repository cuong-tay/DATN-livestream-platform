# Frontend calls the backend directly, without Vite proxy.
# Production fallback in code is https://api.cuongtay.me/api/v1.
# For local development, copy this file to .env and override VITE_API_BASE_URL.

VITE_API_BASE_URL=https://api.cuongtay.me/api/v1

# SockJS/STOMP endpoint. If empty, frontend derives /api/v1/ws from VITE_API_BASE_URL.
VITE_WS_URL=https://api.cuongtay.me/api/v1/ws

# HLS playback URLs should look like:
# https://api.cuongtay.me/hls/<streamKey>.m3u8
VITE_HLS_BASE_URL=https://api.cuongtay.me/hls

# OBS uses this server plus the stream key returned by backend:
# rtmp://rtmp.cuongtay.me/live/<streamKey>
VITE_RTMP_SERVER=rtmp://rtmp.cuongtay.me/live

# Multipart avatar upload endpoint (JWT).
# Can be a relative path, joined with VITE_API_BASE_URL, or an absolute URL.
VITE_AVATAR_UPLOAD_ENDPOINT=/auth/me/avatar

# Multipart field name expected by backend.
VITE_AVATAR_UPLOAD_FIELD=file

# Debug logs for HLS player events.
VITE_DEBUG_STREAM=false

# Debug logs for VOD/session/retry-vod APIs.
VITE_DEBUG_VOD_API=false
